# Environment & secrets
.env
*.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/
ENV/

# Uploads (user data — never commit)
uploads/

# Local storage (runtime data — never commit)
storage/

# Logs
logs/
*.log

# Tests
.pytest_cache/
.coverage
htmlcov/
test_storage_tmp/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
